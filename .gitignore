# Default: ignore everything
*

# Keep directories traversable
!*/

# Repo metadata and root text config
!.gitignore
!.gitattributes
!.editorconfig
!.npmrc
!.nvmrc
!.node-version
!LICENSE

# Source, docs, project, config, and migration text files
!*.md
!*.json
!*.cs
!*.csproj
!*.sln
!*.props
!*.targets
!*.ts
!*.tsx
!*.css
!*.mjs
!*.yaml
!*.yml
!*.sql
!*.svg
!*.ino
!*.example.h
!.gitkeep

# Never track dependency, build, cache, runtime, local, or secret artifacts
node_modules/
.next/
.turbo/
dist/
coverage/
*.tsbuildinfo
.cache/
**/.cache/

bin/
obj/
TestResults/

.deploy/
runtime/generated/
**/runtime/generated/
**/runtime-config.json
**/firmware/masa*/config.h
packages/firmware/arduino/**/config.h

.env
.env.*
!.env.example
**/appsettings.Development.json
**/appsettings.Production.json
**/appsettings.Staging.json
**/appsettings.Local.json
**/appsettings.*.local.json

*.log
logs/
tmp/
temp/
*.tmp
*.pid
*.pid.lock
*.seed
*.sqlite
*.sqlite3
*.db
*.bak
*.cache

*.pem
*.key
*.crt
*.pfx
*.p12

.vs/
.vscode/
.idea/

.DS_Store
Thumbs.db
**/.DS_Store
**/Thumbs.db
