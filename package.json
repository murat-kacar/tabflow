{
  "name": "yenicafe",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:dotnet && pnpm test:ts",
    "test:dotnet": "dotnet test Yenicafe.sln --collect:\"XPlat Code Coverage\"",
    "test:ts": "pnpm -r test",
    "test:coverage": "pnpm test:dotnet && pnpm -r test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "turbo": "^2.6.0"
  }
}
