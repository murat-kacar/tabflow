{
  "name": "tabflow",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "pnpm test:dotnet && pnpm test:ts",
    "test:dotnet": "dotnet test TabFlow.sln --collect:\"XPlat Code Coverage\"",
    "test:ts": "turbo run test",
    "test:coverage": "pnpm test:dotnet && turbo run test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "turbo": "2.9.14"
  }
}
